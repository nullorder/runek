{
  "name": "runek",
  "version": "0.10.1",
  "private": true,
  "description": "Procedural 3D components for the web. Compose walkable worlds from code.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @runek/docs build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "typescript": "catalog:"
  }
}
