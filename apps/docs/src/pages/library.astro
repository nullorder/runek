---
import { getCollection } from 'astro:content'
import { marked } from 'marked'
import changelogRaw from '../../../../CHANGELOG.md?raw'
import LibraryWorld from '../components/world/LibraryWorld.tsx'
import '../styles/global.css'

// The library is the guides reading room; the gallery wing displays the full
// component catalog with an integration guide per exhibit. Markdown is rendered
// to HTML here (build time) and read in-world; marked never reaches the client
// bundle.
const all = await getCollection('docs')
// The changelog entry is an MDX shim that imports the root CHANGELOG.md; the
// in-world reader needs real markdown, so substitute the source file (minus its
// own H1 — the reader already shows the title).
const rawBody = (d: { id: string; body?: string }) =>
  d.id === 'changelog' ? changelogRaw.replace(/^# .*\n/, '') : (d.body ?? '')
const toMeta = (d: (typeof all)[number]) => ({
  slug: d.id,
  title: d.data.title,
  summary: d.data.summary ?? '',
  category: d.data.category,
  component: d.data.component,
  body: marked.parse(rawBody(d), { async: false }) as string,
})
const SHELVED = new Set(['intro', 'guide', 'reference'])
const docs = all
  .filter((d) => SHELVED.has(d.data.category))
  .sort((a, b) => a.data.order - b.data.order)
  .map(toMeta)
const componentDocs = all
  .filter((d) => d.data.category === 'component' && d.data.component)
  .map(toMeta)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Walk the Runek library — a docs world built from the components it documents." />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <title>Runek — the library</title>
    <style>
      html, body { margin: 0; height: 100%; overflow: hidden; background: #0b0d12; }
    </style>
  </head>
  <body>
    <a class="world-back" href="/">← home</a>
    <LibraryWorld client:only="react" docs={docs} componentDocs={componentDocs} />
  </body>
</html>
