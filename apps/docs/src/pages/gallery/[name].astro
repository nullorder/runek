---
import { Code } from 'astro:components'
import ComponentPreview from '../../components/gallery/ComponentPreview.tsx'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { extractPropsInterface, getComponents, getManifest } from '../../lib/registry'

export function getStaticPaths() {
  return getComponents().map((item) => ({ params: { name: item.name }, props: { item } }))
}

const { item } = Astro.props
const manifest = getManifest(item.name)
const source = manifest.files[0]?.content ?? ''
const propsBlock = extractPropsInterface(source)
const deps = [...manifest.registryDependencies, ...manifest.dependencies]
---

<BaseLayout title={`${item.title} — Runek gallery`} description={item.description}>
  <main class="detail">
    <p class="back"><a href="/gallery">← gallery</a></p>
    <p class="eyebrow">{item.category}</p>
    <h1>{item.title}</h1>
    <p class="summary">{item.description}</p>
    <p class="detail-links">
      <a href={`/docs/components/${item.name}`}>Read the docs →</a>
    </p>

    <div class="detail-preview">
      <ComponentPreview client:load title={item.title} detail={true} />
    </div>

    <h2>Install</h2>
    <Code code={`npx @runek/cli add ${item.name}`} lang="bash" theme="night-owl" />
    <p class="deps">
      Pulls: {deps.map((d) => <code>{d}</code>)}
    </p>

    {
      propsBlock && (
        <>
          <h2>Props</h2>
          <Code code={propsBlock} lang="tsx" theme="night-owl" />
        </>
      )
    }

    <h2>Source</h2>
    <details>
      <summary>{manifest.files[0]?.path}</summary>
      <Code code={source} lang="tsx" theme="night-owl" />
    </details>
  </main>
</BaseLayout>
