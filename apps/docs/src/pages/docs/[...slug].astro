---
import { getCollection, render } from 'astro:content'
import ComponentPreview from '../../components/gallery/ComponentPreview.tsx'
import DocLayout from '../../layouts/DocLayout.astro'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map((entry) => ({ params: { slug: entry.id }, props: { entry } }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
// Component docs carry a live, slowly rotating preview of the real component.
const isComponent = entry.data.category === 'component' && Boolean(entry.data.component)
---

<DocLayout
  title={entry.data.title}
  summary={entry.data.summary}
  eyebrow={entry.data.category}
  slug={entry.id}
>
  {
    isComponent && (
      <div class="doc-preview" data-pagefind-ignore>
        <ComponentPreview client:visible title={entry.data.title} />
      </div>
    )
  }
  <Content />
</DocLayout>
