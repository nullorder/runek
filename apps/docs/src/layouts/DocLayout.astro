---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  summary?: string
  eyebrow?: string
}

const { title, summary, eyebrow } = Astro.props
---

<BaseLayout title={`${title} — Runek`} description={summary}>
  <article class="doc">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {summary && <p class="summary">{summary}</p>}
    <slot />
  </article>
</BaseLayout>
