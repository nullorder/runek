---
import { getCollection } from 'astro:content'
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  summary?: string
  eyebrow?: string
  /** Content-collection id of the current doc; drives the sidebar highlight + pager. */
  slug?: string
}

const { title, summary, eyebrow, slug } = Astro.props

const categoryOrder = ['intro', 'guide', 'component', 'reference']
const docs = (await getCollection('docs')).sort(
  (a, b) =>
    categoryOrder.indexOf(a.data.category) - categoryOrder.indexOf(b.data.category) ||
    a.data.order - b.data.order ||
    a.data.title.localeCompare(b.data.title),
)
const groups = categoryOrder
  .map((category) => ({ category, items: docs.filter((d) => d.data.category === category) }))
  .filter((g) => g.items.length > 0)

const current = slug ? docs.findIndex((d) => d.id === slug) : -1
const prev = current > 0 ? docs[current - 1] : null
const next = current >= 0 && current < docs.length - 1 ? docs[current + 1] : null
---

<BaseLayout title={`${title} — Runek`} description={summary}>
  <div class="doc-shell">
    <aside class="doc-sidebar">
      {/* show-keyboard-hints="false": the hint chips need ~220px and overflow this
          narrow column; the mobile modal below keeps its own hints. The modal owns
          mod+k, so the searchbox takes "/" (its shortcut chip displays whichever). */}
      <div class="doc-search" data-pf-theme="dark">
        <pagefind-searchbox show-sub-results show-keyboard-hints="false" shortcut="/"></pagefind-searchbox>
      </div>
      <nav aria-label="Documentation">
        {
          groups.map((group) => (
            <section>
              <h4>{group.category}</h4>
              <ul>
                {group.items.map((doc) => (
                  <li>
                    <a href={`/docs/${doc.id}`} aria-current={doc.id === slug ? 'page' : undefined}>
                      {doc.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </nav>
    </aside>

    <article class="doc" data-pagefind-body>
      {/* Mobile-only search entry: the sidebar (and its searchbox) is hidden ≤900px. */}
      {/* instance="modal" keeps this decoupled from the sidebar searchbox — a shared
          instance would sync queries and pop the sidebar dropdown open behind the modal. */}
      <div class="doc-search-mobile" data-pf-theme="dark" data-pagefind-ignore>
        <pagefind-modal-trigger instance="modal" hide-shortcut></pagefind-modal-trigger>
      </div>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {summary && <p class="summary">{summary}</p>}
      <p class="explore-3d" data-pagefind-ignore><a href="/library">⌖ Explore the library in 3D →</a></p>
      <slot />
      {
        (prev || next) && (
          <nav class="doc-pager" aria-label="Adjacent docs" data-pagefind-ignore>
            {prev ? <a href={`/docs/${prev.id}`}>← {prev.data.title}</a> : <span />}
            {next ? <a href={`/docs/${next.id}`}>{next.data.title} →</a> : <span />}
          </nav>
        )
      }
    </article>
  </div>

  {/* Search modal, opened by the mobile trigger or mod+k anywhere on the page.
      Lives outside .doc-shell so hiding the trigger never hides the modal. */}
  <div class="doc-search-modal" data-pf-theme="dark">
    <pagefind-modal instance="modal"></pagefind-modal>
  </div>

  {/* Pagefind search: assets are emitted into dist/pagefind by `pagefind --site dist`
      (production build only), so this is gated on PROD to avoid dev 404s. The script
      defines the <pagefind-searchbox> custom element; in dev it stays undefined and
      renders nothing. */}
  {
    import.meta.env.PROD && (
      <Fragment>
        <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
        <script is:inline type="module" src="/pagefind/pagefind-component-ui.js" />
      </Fragment>
    )
  }
</BaseLayout>
